# ============================================================================
# Sovereign Office of the Chief Justice & Trustee — Environment Variables
#
# Copy this file to .env and fill in every value marked REQUIRED before
# running docker compose up.
#
# Never commit your .env file to version control.
# ============================================================================


# ── Database ─────────────────────────────────────────────────────────────────

# Full PostgreSQL connection string. REQUIRED.
# Local docker-compose default:
#   postgresql://sovereign:changeme@postgres:5432/sovereign_office
# Azure Database for PostgreSQL example:
#   postgresql://adminuser@myserver:StrongPass!@myserver.postgres.database.azure.com:5432/sovereign_office?sslmode=require
DATABASE_URL=postgresql://sovereign:changeme@postgres:5432/sovereign_office

# Password for the local postgres service (docker-compose only).
# Ignored when DATABASE_URL points to an external host.
POSTGRES_PASSWORD=changeme


# ── Security & Sessions ───────────────────────────────────────────────────────

# Secret used to sign session JWTs. REQUIRED.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# Internal API-to-API authentication key. REQUIRED.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SERVICE_KEY=

# Optional: separate key for M365 service integrations.
M365_SERVICE_KEY=


# ── Application URLs ──────────────────────────────────────────────────────────

# Public-facing base URL of the API server (no trailing slash). REQUIRED.
# Used for OAuth redirect URIs, PDF download links, and CORS.
# Example: https://api.yourdomain.com  or  http://20.x.x.x:8080
APP_URL=http://localhost:8080

# URL of the Sovereign Office Dashboard where users land after Microsoft login.
# REQUIRED when deploying with Docker or Azure (separate domains/containers).
# Must NOT have a trailing slash.
# Docker Compose example: https://sovereign.yourdomain.com
# Local / Replit default (leave unset): /sovereign-dashboard
SOVEREIGN_DASHBOARD_URL=https://sovereign.yourdomain.com


# ── Azure Entra ID (Active Directory / SSO) ──────────────────────────────────

# Found in Azure Portal → App Registrations → your app → Overview. REQUIRED.
AZURE_ENTRA_TENANT_ID=

# Application (client) ID from your Azure App Registration. REQUIRED.
AZURE_ENTRA_CLIENT_ID=

# Client secret from Azure App Registration → Certificates & secrets. REQUIRED.
AZURE_ENTRA_CLIENT_SECRET=


# ── Azure OpenAI ──────────────────────────────────────────────────────────────

# HTTPS endpoint for your Azure OpenAI resource.
# Example: https://my-resource.openai.azure.com/
AZURE_OPENAI_ENDPOINT=

# API key for the Azure OpenAI resource.
AZURE_OPENAI_API_KEY=

# Name of the deployed model (e.g. gpt-4o, gpt-4-turbo).
AZURE_OPENAI_DEPLOYMENT=


# ── CI/CD & Azure Container Registry ─────────────────────────────────────────

# Login server for your Azure Container Registry.
# Used by docker-compose.yml to pull pre-built images in production.
# Set this to your actual ACR login server on the Azure VM.
# Example: sovereignoffice.azurecr.io
# For local development you can leave this unset — images are built from source
# via the build: blocks in docker-compose.yml.
ACR_REGISTRY=

# Optional: pin to a specific image tag (default: latest).
# Set to a short Git SHA (e.g. a1b2c3d4) to roll back to a previous build.
IMAGE_TAG=latest


# ── Logging ───────────────────────────────────────────────────────────────────

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
