# =============================================================================
# Sovereign Office of the Chief Justice & Trustee
# ENVIRONMENT CONFIGURATION
#
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.template .env
#   2. Fill in every value marked  ← FILL IN
#   3. Never share or commit your .env file
# =============================================================================


# =============================================================================
# SECTION 1 — DATABASE
# =============================================================================

# Option A — Use the built-in PostgreSQL container (simplest, good for testing)
# Leave DATABASE_URL pointing to the postgres container and set POSTGRES_PASSWORD.
DATABASE_URL=postgresql://sovereign:CHANGE_THIS_PASSWORD@postgres:5432/sovereign_office
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD          # ← FILL IN (any strong password)

# Option B — Use Azure Database for PostgreSQL (recommended for production)
# Comment out the two lines above and uncomment this one:
# DATABASE_URL=postgresql://adminuser@myserver:MyPassword123!@myserver.postgres.database.azure.com:5432/sovereign_office?sslmode=require


# =============================================================================
# SECTION 2 — SECURITY KEYS  (generate random values — never reuse)
# =============================================================================

# Signs all session tokens. Must be a long random string.
# Generate:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=                                 # ← FILL IN

# Internal service-to-service authentication key.
# Generate:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SERVICE_KEY=                                    # ← FILL IN

# Optional — Microsoft 365 integration key (leave blank if not used)
M365_SERVICE_KEY=


# =============================================================================
# SECTION 3 — YOUR SERVER URLs
# =============================================================================

# Public URL of your API server (no trailing slash).
# Use your VM's public IP or domain name.
# Examples:
#   http://20.123.45.67:8080
#   https://api.sovereignoffice.org
APP_URL=http://YOUR-VM-IP:8080                  # ← FILL IN

# URL where the Sovereign Dashboard is accessible (no trailing slash).
# This is where users land after Microsoft login.
# Examples:
#   http://20.123.45.67:3001
#   https://sovereign.sovereignoffice.org
SOVEREIGN_DASHBOARD_URL=http://YOUR-VM-IP:3001  # ← FILL IN


# =============================================================================
# SECTION 4 — MICROSOFT AZURE ENTRA ID (Single Sign-On)
# Find these in: Azure Portal → App Registrations → your app → Overview
# =============================================================================

# Directory (tenant) ID
AZURE_ENTRA_TENANT_ID=                          # ← FILL IN

# Application (client) ID
AZURE_ENTRA_CLIENT_ID=                          # ← FILL IN

# Client secret value (from Certificates & secrets tab)
AZURE_ENTRA_CLIENT_SECRET=                      # ← FILL IN


# =============================================================================
# SECTION 5 — AZURE OPENAI  (AI document extraction and legal analysis)
# Find these in: Azure Portal → your OpenAI resource → Keys and Endpoint
# =============================================================================

# HTTPS endpoint (include trailing slash)
# Example: https://my-openai.openai.azure.com/
AZURE_OPENAI_ENDPOINT=                          # ← FILL IN

# API Key (either Key 1 or Key 2)
AZURE_OPENAI_API_KEY=                           # ← FILL IN

# The deployment name you gave your model in Azure OpenAI Studio
# Example: gpt-4o  or  tribal-gpt4o
AZURE_OPENAI_DEPLOYMENT=                        # ← FILL IN


# =============================================================================
# SECTION 6 — AZURE CONTAINER REGISTRY  (where Docker images are stored)
# Fill this in after running 1-provision-azure.sh
# =============================================================================

# Login server printed by 1-provision-azure.sh
# Example: sovereignoffice.azurecr.io
ACR_REGISTRY=                                   # ← FILL IN (after provisioning)

# Image tag — leave as 'latest' unless you need to pin a specific version
IMAGE_TAG=latest

# ACR credentials (printed by 1-provision-azure.sh)
ACR_USERNAME=                                   # ← FILL IN (after provisioning)
ACR_PASSWORD=                                   # ← FILL IN (after provisioning)


# =============================================================================
# SECTION 7 — OPTIONAL SETTINGS
# =============================================================================

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Set to 'true' if DATABASE_URL points to Azure Database for PostgreSQL
# (this skips starting the local postgres container)
USE_AZURE_DB=false
